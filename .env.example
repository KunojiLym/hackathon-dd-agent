# Shared runtime config — copy to .env at repo root (never commit .env)
# Backend loads this via backend/config.py; frontend via frontend/env_shared.py

# Bright Data (Stage 2)
BRIGHT_DATA_API_KEY=YOUR_BRIGHT_DATA_API_KEY_HERE
BRIGHT_DATA_SERP_ZONE=your_serp_zone_name
BRIGHT_DATA_BROWSER_USERNAME=brd-customer-hl_XXXXX-zone-your_browser_zone_name
BRIGHT_DATA_BROWSER_PASSWORD=YOUR_BRIGHT_DATA_BROWSER_PASSWORD_HERE
# BRIGHT_DATA_CUSTOMER_ID=hl_XXXXX
# BRIGHT_DATA_BROWSER_ZONE=your_browser_zone_name

# Daytona (Stage 3 + optional deploy)
DAYTONA_API_KEY=YOUR_DAYTONA_API_KEY_HERE
DAYTONA_SERVER_URL=https://app.daytona.io/api
DAYTONA_TARGET=local

# LLM Stage 4 — TokenRouter (default)
LLM_PROVIDER=tokenrouter
TOKENROUTER_API_KEY=YOUR_TOKENROUTER_API_KEY_HERE
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
TOKENROUTER_MODEL=MiniMax-M3

# OpenRouter alternative (set LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
# OPENROUTER_MODEL=minimax-v3

# Direct Kimi / Moonshot API (set LLM_PROVIDER=kimi; also memo fallback)
# KIMI_API_KEY=YOUR_KIMI_API_KEY_HERE
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=moonshot-v1-auto

# Stage 5 memo polish (optional; POST /screen/{run_id}/memo/sensenova)
# SENSENOVA_API_KEY=YOUR_SENSENOVA_API_KEY_HERE
# SENSENOVA_BASE_URL=https://api.sensenova.cn/compatible-mode/v1
# SENSENOVA_MODEL=SenseNova-5

# Stage 1.5 entity resolution
CLARIFICATION_ENABLED=true
DISCOVERY_SERP_RESULTS=5

# Runtime
RUNS_DIR=./runs
AGENT_VERSION=0.1.0-hackathon
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# Frontend
BACKEND_URL=http://127.0.0.1:8000
USE_MOCK_DATA=false
POLL_INTERVAL_SECONDS=5
POLL_TIMEOUT_SECONDS=900
